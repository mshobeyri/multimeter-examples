type: test
title: Data driven echo test
description: Loops over rows from a CSV file and calls the echo API for each message
import:
  echo: echo_api.mmt
  messages: messages.csv
steps:
  - for: row of messages
    steps:
      - call: echo
        id: result
        inputs:
          message: ${row.message}
        expect:
          status: 200
          echoed_message: ${row.message}
          request_method: ${row.expected_method}
        title: ${row.message}
