type: api
title: GraphQL query with variables
description: Fetch a single country by code using GraphQL variables
inputs:
  countryCode: BR
outputs:
  country_name: body.data.country.name
  capital: body.data.country.capital
url: https://countries.trevorblades.com/graphql
protocol: graphql
graphql:
  operation: |
    query GetCountry($code: ID!) {
      country(code: $code) {
        name
        capital
        currency
        languages {
          name
        }
      }
    }
  variables:
    code: i:countryCode
  operationName: GetCountry
