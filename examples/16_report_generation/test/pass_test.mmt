type: test
title: Passing Test
description: A test that should pass
import:
  echo: ../api/echo.mmt
steps:
  - call: echo
    id: result
    inputs:
      message: pass test
    expect:
      status_code: 200
  - assert:
      actual: ${result.status_code}
      operator: ==
      expected: "200"
      report: all
