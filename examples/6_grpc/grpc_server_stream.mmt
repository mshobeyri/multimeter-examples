type: api
title: gRPC server streaming
description: Open a server-streaming gRPC call to receive multiple responses
outputs:
  first_message: body[0].message
url: grpc://localhost:50051
protocol: grpc
grpc:
  proto: ./greeter.proto
  service: greeter.Greeter
  method: SayHelloStream
  stream: server
  message:
    name: Multimeter
    count: 3
